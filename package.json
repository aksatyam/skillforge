{
  "name": "skillforge",
  "version": "0.1.0",
  "private": true,
  "description": "SkillForge AI — AI-Powered Employee Skill Assessment Platform (Qualtech)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:generate": "pnpm --filter @skillforge/db generate",
    "db:migrate:dev": "pnpm --filter @skillforge/db migrate:dev",
    "db:migrate:deploy": "pnpm --filter @skillforge/db migrate:deploy",
    "db:seed": "pnpm --filter @skillforge/db seed",
    "db:reset": "pnpm --filter @skillforge/db reset",
    "local:up": "./tools/local-up.sh",
    "local:down": "./tools/local-down.sh",
    "local:status": "./tools/local-status.sh",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .gitignore",
    "tenant:check": "bash .claude/skills/sf-tenant-check/scan.sh || true",
    "security:audit": "pnpm audit --audit-level=high && pnpm semgrep --config=auto --error --severity=ERROR || true"
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0",
    "@types/node": "^20.12.7",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
