# SkillForge AI — local development environment
# Copy to .env and fill in real values

# ---- Runtime ----
NODE_ENV=development
LOG_LEVEL=debug

# ---- Postgres (local: brew services start postgresql@15) ----
# Application role — RLS-enforced. Used for every tenant-scoped query.
DATABASE_URL=postgresql://skillforge:skillforge@localhost:5432/skillforge?schema=public
# Admin role — BYPASSRLS. Used ONLY for pre-tenant auth flows,
# audit log writes, and super_admin cross-tenant ops.
DATABASE_URL_ADMIN=postgresql://skillforge_admin:skillforge_admin@localhost:5432/skillforge?schema=public
# Shadow DB is used by Prisma for migration diffs
SHADOW_DATABASE_URL=postgresql://skillforge_admin:skillforge_admin@localhost:5432/skillforge_shadow?schema=public

# ---- Redis (local: brew services start redis) ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
JWT_SECRET=dev-only-change-in-prod-use-32-bytes-min
JWT_ACCESS_TTL=900            # 15 min
JWT_REFRESH_TTL=604800        # 7 days

# SSO (Sprint 6 — Keycloak OIDC)
# Flip to true to surface the "Sign in with SSO" button on /login.
# (Password login still works when a local passwordHash exists.)
NEXT_PUBLIC_SSO_ENABLED=false
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=qualtech
KEYCLOAK_CLIENT_ID=skillforge-web
KEYCLOAK_CLIENT_SECRET=
# Shared secret between Next BFF (callback route) and the
# assessment-service POST /auth/sso/exchange bridge. Must be identical
# in both processes. >= 32 chars in prod. Rotate via env redeploy.
SSO_BRIDGE_SECRET=dev-shared-secret-change-in-prod

# ---- BFF session cookie bridge (apps/web Route Handlers) ----
# Sprint 5 #2: JWTs live in httpOnly cookies set by Next.js. The Route
# Handlers in apps/web/app/api/session/* proxy to the assessment service
# using this base URL. The browser never sees the JWT.
ASSESSMENT_API=http://localhost:4001
# Optional — leave empty for the default (current host). Set to e.g.
# ".skillforge.example" to share cookies across subdomains in prod.
SESSION_COOKIE_DOMAIN=
# Cookies are `Secure` automatically when NODE_ENV=production; relaxed in
# development so they flow over http://localhost.

# ---- Claude (Phase 2, optional for Phase 1) ----
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-opus-4-7

# ---- File Storage ----
# Local: use ./local-storage/ for artifacts. Phase 3: switch to S3.
STORAGE_MODE=local
STORAGE_LOCAL_PATH=./local-storage
S3_BUCKET=
S3_REGION=

# ---- Email (local: mailhog or Postfix disabled) ----
EMAIL_MODE=console            # console | smtp | ses
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@skillforge.local

# ---- Reminder cron (Sprint 2 feature #12 + Sprint 5 tz fix) ----
REMINDER_CRON=0 9 * * *       # scheduler fires in UTC
REMINDER_DAYS_BEFORE_DEADLINE=7
# Per-tenant idempotency bucket uses organization.settings_json.timezone
# (IANA tz like 'Asia/Kolkata'). Falls back to UTC if missing/invalid.

# ---- App base URL (used in email template links; Sprint 5) ----
APP_BASE_URL=http://localhost:3000

# ---- Swagger docs ----
# DISABLE_SWAGGER=true        # uncomment in prod to hide /api/docs

# ---- Service ports ----
PORT_WEB=3000
PORT_ASSESSMENT=4001
PORT_FRAMEWORK=4002
PORT_AI_EVALUATION=4003
PORT_ANALYTICS=4004
PORT_NOTIFICATION=4005
PORT_INTEGRATION=4006

# ---- Feature flags ----
FEATURE_AI_SCORING=false       # enable Phase 2 AI flow
FEATURE_PEER_REVIEW=false      # enable peer review module
FEATURE_BIAS_DETECTION=false

# ---- Observability ----
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
