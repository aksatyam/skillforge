{
  "name": "@skillforge/assessment-service",
  "version": "0.1.0",
  "private": true,
  "description": "SkillForge assessment service — cycle + self/manager/peer/AI score orchestration",
  "scripts": {
    "build": "nest build",
    "dev": "DOTENV_CONFIG_PATH=../../.env ts-node-dev --respawn --transpile-only -r dotenv/config -r tsconfig-paths/register src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.658.0",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^5.22.0",
    "@skillforge/db": "workspace:*",
    "@skillforge/shared-types": "workspace:*",
    "@skillforge/tenant-guard": "workspace:*",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^7.2.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.3",
    "nodemailer": "^6.9.14",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.4",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.26",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^6.4.15",
    "dotenv": "^17.4.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
